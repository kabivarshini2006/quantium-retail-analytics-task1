# Cell 1: Imports
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import re

%matplotlib inline
sns.set(style="whitegrid")

# Cell 2: Read data
transaction = pd.read_csv("QVI_transaction_data.csv")
behaviour  = pd.read_csv("QVI_purchase_behaviour.csv")

print("Transactions shape:", transaction.shape)
print("Behaviour shape:", behaviour.shape)

# Cell 3: Quick look
display(transaction.head())
display(behaviour.head())

transaction.info()
behaviour.info()

# Cell 4: Fix DATE (Excel integer date → real date)
transaction['DATE'] = pd.to_datetime(transaction['DATE'], unit='D', origin='1899-12-30')
print(transaction['DATE'].describe(datetime_is_numeric=True))

# Cell 5: Examine PROD_NAME – most frequent products
print(transaction['PROD_NAME'].value_counts().head(20))

# Cell 6: Extract pack size (using regex)
transaction['PACK_SIZE'] = transaction['PROD_NAME'].str.extract(r'(\d+)g?', expand=False).astype(float)
print(transaction['PACK_SIZE'].value_counts().sort_index())

# Visualize pack size distribution
plt.figure(figsize=(10,5))
sns.histplot(transaction['PACK_SIZE'], bins=30)
plt.title("Pack Size Distribution (grams)")
plt.show()

# Cell 7: Extract & clean brand name
def extract_brand(name):
    # Take first word, fix known inconsistencies
    brand = name.split()[0].upper()
    corrections = {
        'RED': 'RRD', 'DORITO': 'DORITOS', 'SNBTS': 'SUNBITES',
        'INFZNS': 'INFUZIONS', 'WW': 'WOOLWORTHS', 'SMITH': 'SMITHS',
        'NCC': 'NATURAL', 'GRAIN': 'GRNWVES'
    }
    return corrections.get(brand, brand)

transaction['BRAND'] = transaction['PROD_NAME'].apply(extract_brand)
print(transaction['BRAND'].value_counts().head(15))

# Cell 8: Outlier detection – suspicious large quantities
print(transaction['PROD_QTY'].describe())
print(transaction[transaction['PROD_QTY'] >= 50])          # → 200 qty outlier

# Remove outlier customer (LYLTY_CARD_NBR == 226000)
transaction = transaction[transaction['LYLTY_CARD_NBR'] != 226000].copy()
print("After removal:", transaction['PROD_QTY'].describe())

# Cell 9: Transactions per day + Christmas dip check
daily = transaction.groupby('DATE').size().reset_index(name='TXN_COUNT')

all_dates = pd.date_range(start='2018-07-01', end='2019-06-30')
daily_full = pd.DataFrame({'DATE': all_dates}).merge(daily, on='DATE', how='left').fillna(0)

plt.figure(figsize=(14,5))
plt.plot(daily_full['DATE'], daily_full['TXN_COUNT'])
plt.title("Daily Transactions – notice Dec 25 dip")
plt.axvline(pd.to_datetime('2018-12-25'), color='red', linestyle='--', label='Christmas')
plt.legend()
plt.show()

# Zoom December
dec = daily_full[daily_full['DATE'].dt.month == 12]
plt.figure(figsize=(12,5))
sns.lineplot(x='DATE', y='TXN_COUNT', data=dec)
plt.title("December Transactions")
plt.xticks(rotation=45)
plt.show()

# Cell 10: Merge datasets
data = transaction.merge(behaviour, on='LYLTY_CARD_NBR', how='left')
print(data.isna().sum())   # should be 0

# Cell 11: Key customer segment metrics

# Total sales by segment
sales_seg = data.groupby(['LIFESTAGE','PREMIUM_CUSTOMER'])['TOT_SALES'].sum().reset_index()
plt.figure(figsize=(12,6))
sns.barplot(x='LIFESTAGE', y='TOT_SALES', hue='PREMIUM_CUSTOMER', data=sales_seg)
plt.xticks(rotation=45, ha='right')
plt.title("Total Sales by Lifestage & Premium Segment")
plt.tight_layout()
plt.show()

# Number of unique customers
cust_seg = data.groupby(['LIFESTAGE','PREMIUM_CUSTOMER'])['LYLTY_CARD_NBR'].nunique().reset_index(name='CUSTOMERS')
sns.barplot(x='LIFESTAGE', y='CUSTOMERS', hue='PREMIUM_CUSTOMER', data=cust_seg)
plt.xticks(rotation=45, ha='right')
plt.title("Unique Customers by Segment")
plt.show()

# Avg units per customer
units = data.groupby(['LIFESTAGE','PREMIUM_CUSTOMER']).agg(
    UNITS=('PROD_QTY','sum'),
    CUST=('LYLTY_CARD_NBR','nunique')
).reset_index()
units['AVG_UNITS'] = units['UNITS'] / units['CUST']

sns.barplot(x='LIFESTAGE', y='AVG_UNITS', hue='PREMIUM_CUSTOMER', data=units)
plt.xticks(rotation=45)
plt.title("Avg Units per Customer")
plt.show()

# Avg price per unit
price = data.groupby(['LIFESTAGE','PREMIUM_CUSTOMER']).agg(
    SALES=('TOT_SALES','sum'),
    QTY=('PROD_QTY','sum')
).reset_index()
price['AVG_PRICE'] = price['SALES'] / price['QTY']

sns.barplot(x='LIFESTAGE', y='AVG_PRICE', hue='PREMIUM_CUSTOMER', data=price)
plt.xticks(rotation=45)
plt.title("Average Price per Unit ($)")
plt.show()

# Cell 12: Statistical test – Mainstream young/mid singles/couples pay more?
from scipy.stats import ttest_ind

mainstream = data[
    data['LIFESTAGE'].isin(['YOUNG SINGLES/COUPLES', 'MIDAGE SINGLES/COUPLES']) &
    (data['PREMIUM_CUSTOMER'] == 'Mainstream')
]
premium_budget = data[
    data['LIFESTAGE'].isin(['YOUNG SINGLES/COUPLES', 'MIDAGE SINGLES/COUPLES']) &
    (data['PREMIUM_CUSTOMER'] != 'Mainstream')
]

main_price = mainstream['TOT_SALES'] / mainstream['PROD_QTY']
other_price = premium_budget['TOT_SALES'] / premium_budget['PROD_QTY']

t_stat, p_val = ttest_ind(main_price, other_price, equal_var=False)
print(f"t-test p-value: {p_val:.2e} → significantly higher price in mainstream")

# Cell 13: Deep dive – affinity for young mainstream singles/couples
target = data[(data['LIFESTAGE'] == 'YOUNG SINGLES/COUPLES') & (data['PREMIUM_CUSTOMER'] == 'Mainstream')]
other  = data[~((data['LIFESTAGE'] == 'YOUNG SINGLES/COUPLES') & (data['PREMIUM_CUSTOMER'] == 'Mainstream'))]

brand_aff = (
    target.groupby('BRAND')['PROD_QTY'].sum() / target['PROD_QTY'].sum()
).to_frame('target_share').join(
    other.groupby('BRAND')['PROD_QTY'].sum() / other['PROD_QTY'].sum()
).rename(columns={'PROD_QTY':'other_share'})
brand_aff['affinity'] = brand_aff['target_share'] / brand_aff['other_share']
print(brand_aff.sort_values('affinity', ascending=False).head(10))

# Same for pack size
pack_aff = (
    target.groupby('PACK_SIZE')['PROD_QTY'].sum() / target['PROD_QTY'].sum()
).to_frame('target_share').join(
    other.groupby('PACK_SIZE')['PROD_QTY'].sum() / other['PROD_QTY'].sum()
).rename(columns={'PROD_QTY':'other_share'})
pack_aff['affinity'] = pack_aff['target_share'] / pack_aff['other_share']
print(pack_aff.sort_values('affinity', ascending=False).head(8))